# Copy this file to .env and fill in the values.
# Never commit .env — it is gitignored.

PERPLEXITY_API_KEY=
LANGSMITH_API_KEY=

# Browserless headless rendering fallback for SPA docs
# Get your API key from https://www.browserless.io/
BROWSERLESS_API_KEY=
BROWSERLESS_ENDPOINT=https://chrome.browserless.io
# Set to 'true' to enable the fallback (flip after smoke-testing the deploy)
LENSY_HEADLESS_FALLBACK_ENABLED=false
